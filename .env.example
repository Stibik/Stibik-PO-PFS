# Скопируйте этот файл в .env и заполните своими значениями.
# .env никогда не должен попадать в git / публичный доступ — там секреты.

# Порт сервера (хостинг обычно подставляет свой, локально можно оставить 3000)
PORT=3000

# Секрет для подписи сессий — придумайте длинную случайную строку
SESSION_SECRET=change-me-to-a-long-random-string

# Логин/пароль администратора, создаются один раз при первом запуске
# (если пользователей ещё нет в базе). Дальше меняются из интерфейса.
ADMIN_USER=admin
ADMIN_PASS=admin

# Токены API "Магазин на Kaspi.kz" — по одному на каждый магазин.
# Получаются в кабинете продавца Kaspi (раздел API/интеграции).
# Если не заполнены — просто не будет доступна синхронизация с этим магазином.
KASPI_TOKEN_SHOP1=
KASPI_SHOP1_NAME=Магазин 1

KASPI_TOKEN_SHOP2=
KASPI_SHOP2_NAME=Магазин 2

KASPI_TOKEN_SHOP3=
KASPI_SHOP3_NAME=Магазин 3

NODE_ENV=production

# Пути к данным — ВАЖНО для хостинга с постоянным диском (см. README, раздел «Хостинг»).
# Если не указаны — данные будут храниться рядом с кодом и могут теряться при пересборке/рестарте.
# DB_PATH=/data/data.sqlite
# UPLOAD_DIR=/data/uploads

